# vole configuration
# Copy to .env and adjust as needed:
#   cp .env.example .env

# HTTP listen address
LISTEN_ADDR=:7007

# Max time to read the target page
READ_TIMEOUT=30s

# Max time to establish a connection
CONNECT_TIMEOUT=15s

# Max HTML body size in bytes (10 MB)
MAX_BODY_SIZE=10485760

# Minimum content length (in characters) before returning content_too_short warning
MIN_CONTENT_LENGTH=500

# User-Agent sent with requests
USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/127.0.0.0 Safari/537.36"
