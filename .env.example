# vole configuration
# Copy to .env and adjust as needed:
#   cp .env.example .env

# HTTP listen address
LISTEN_ADDR=:9090

# Max time to read the target page
READ_TIMEOUT=30s

# Max time to establish a connection
CONNECT_TIMEOUT=15s

# Max HTML body size in bytes (10 MB)
MAX_BODY_SIZE=10485760

# User-Agent sent with requests
USER_AGENT=vole/1.0
